; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="fps-godot-template"
config/tags=PackedStringArray("3d", "fps")
run/main_scene="uid://bbnssv0o4f2j3"
config/features=PackedStringArray("4.6", "GL Compatibility")
run/max_fps=60
config/icon="uid://bdqc1yc4gxwtw"

[audio]

buses/default_bus_layout="res://assets/resources/master_bus.tres"

[autoload]

EventBus="*res://addons/fp_framework/event_bus.gd"
GameSettings="*res://src/globals/game_settings.gd"
SceneManager="*res://addons/fp_framework/scene_manager.gd"
AudioManager="*res://addons/fp_framework/audio_manager.gd"
SaveManager="*res://addons/fp_framework/save_manager.gd"
Localization="*res://addons/fp_framework/localization.gd"
Debug="*res://addons/fp_framework/debug_overlay.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/resizable=false

[editor_plugins]

enabled=PackedStringArray("res://addons/fp_framework/plugin.cfg")

[global_group]

player=""
enemy=""
interactable=""
character=""
destructible=""
movable=""

